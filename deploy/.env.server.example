# Use an immutable registry digest for production, for example:
# ollama/ollama@sha256:<manifest-digest>
OLLAMA_IMAGE=REPLACE_WITH_PINNED_OLLAMA_IMAGE
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MAX_QUEUE=32
OLLAMA_CONTEXT_LENGTH=8192

# Set before running scripts/pull_and_lock_model.sh.
MODEL_NAME=REPLACE_WITH_EXACT_OLLAMA_TAG
PROFILE_ID=server-local-model
AGENT_IMAGE=trace-redteam-agent:server
